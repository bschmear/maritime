{
  "id": "post-purchase-feedback",
  "name": "Post-Purchase Experience Survey",
  "description": "Gather satisfaction data and insights after a boat purchase",
  "public_description": "Congratulations on your new boat! We'd love to hear how your buying experience went.",
  "type": "feedback",
  "icon": "directions_boat",
  "category": "Post-Transaction",
  "questions": [
    {
      "type": "nps",
      "label": "How satisfied are you with your overall buying experience?",
      "required": true,
      "order": 1,
      "options": null,
      "config": {
        "min": 0,
        "max": 10,
        "labels": {
          "min": "Not satisfied",
          "max": "Extremely satisfied"
        }
      }
    },
    {
      "type": "rating",
      "label": "How knowledgeable was your sales team about the boat you purchased?",
      "required": true,
      "order": 2,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "rating",
      "label": "How smooth was the financing and paperwork process?",
      "required": true,
      "order": 3,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "multiple_choice",
      "label": "Did you receive a proper boat walkthrough and orientation before leaving the lot?",
      "required": true,
      "order": 4,
      "options": ["Yes, very thorough", "Yes, but could have been more detailed", "No, not really", "I didn't need one"]
    },
    {
      "type": "multiple_choice",
      "label": "Did the boat meet your expectations once you got it on the water?",
      "required": true,
      "order": 5,
      "options": ["Exceeded expectations", "Met expectations", "Mostly met expectations", "Did not meet expectations"]
    },
    {
      "type": "multiple_choice",
      "label": "Would you purchase from us again?",
      "required": true,
      "order": 6,
      "options": ["Yes, definitely", "Yes, probably", "Not sure", "Probably not", "Definitely not"]
    },
    {
      "type": "multiple_choice",
      "label": "Would you recommend us to a friend or family member?",
      "required": true,
      "order": 7,
      "options": ["Yes, definitely", "Yes, probably", "Not sure", "Probably not", "Definitely not"]
    },
    {
      "type": "textarea",
      "label": "What could we have done better?",
      "required": false,
      "order": 8,
      "options": null,
      "config": {
        "rows": 4
      }
    }
  ]
}
