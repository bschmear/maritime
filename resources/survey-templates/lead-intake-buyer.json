{
  "id": "lead-intake-buyer",
  "name": "New Buyer Lead Intake",
  "description": "Qualify new buyer leads from website, ads, or walk-ins",
  "public_description": "Tell us a little about what you're looking for and we'll help match you with the right boat.",
  "type": "lead",
  "icon": "anchor",
  "category": "Lead Generation",
  "questions": [
    {
      "type": "multiple_choice",
      "label": "Are you currently working with another dealership?",
      "required": true,
      "order": 1,
      "options": ["Yes", "No", "Just browsing around"]
    },
    {
      "type": "dropdown",
      "label": "What type of boat are you most interested in?",
      "required": true,
      "order": 2,
      "options": ["Pontoon", "Bowrider / Runabout", "Fishing / Bass Boat", "Ski / Wakeboard Boat", "Deck Boat", "Sailboat", "Center Console", "Cruiser / Cabin Boat", "Jon Boat", "Not sure yet"]
    },
    {
      "type": "dropdown",
      "label": "What is your approximate budget?",
      "required": true,
      "order": 3,
      "options": ["Under $20k", "$20k - $40k", "$40k - $75k", "$75k - $125k", "$125k - $250k", "Over $250k", "Not sure yet"]
    },
    {
      "type": "multiple_choice",
      "label": "Are you looking for a new or pre-owned boat?",
      "required": true,
      "order": 4,
      "options": ["New only", "Pre-owned only", "Open to either"]
    },
    {
      "type": "multiple_choice",
      "label": "How soon are you looking to purchase?",
      "required": true,
      "order": 5,
      "options": ["Within 30 days", "1-3 months", "3-6 months", "Just exploring for now"]
    },
    {
      "type": "multiple_choice",
      "label": "Will you need financing?",
      "required": true,
      "order": 6,
      "options": ["Yes", "No, paying cash", "Not sure yet"]
    },
    {
      "type": "dropdown",
      "label": "What is your primary use for the boat?",
      "required": true,
      "order": 7,
      "options": ["Family recreation", "Fishing", "Watersports / Wakeboarding", "Cruising / Overnight trips", "Racing", "Commercial use", "Multiple purposes"]
    },
    {
      "type": "multiple_choice",
      "label": "Do you have a trade-in?",
      "required": false,
      "order": 8,
      "options": ["Yes", "No"]
    },
    {
      "type": "multiple_choice",
      "label": "How would you prefer we follow up?",
      "required": true,
      "order": 9,
      "options": ["Phone call", "Text message", "Email", "No preference"]
    },
    {
      "type": "textarea",
      "label": "Anything else we should know about what you're looking for?",
      "required": false,
      "order": 10,
      "options": null,
      "config": {
        "placeholder": "Example: Need to fit 8 people, want a Bimini top, prefer a specific brand, etc.",
        "rows": 3
      }
    }
  ]
}
