{
  "id": "lender-experience",
  "name": "Mortgage or Lender Experience Feedback",
"description": "Gauge client satisfaction with preferred lender partners",
"public_description": "Please provide feedback regarding your experience with the lender to assist in evaluating satisfaction and service quality",
  "type": "feedback",
  "icon": "fa-money-check",
  "category": "Partner Feedback",
  "questions": [
    {
      "type": "rating",
      "label": "How smooth was your financing process?",
      "required": true,
      "order": 1,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "multiple_choice",
      "label": "Were loan terms clearly explained?",
      "required": true,
      "order": 2,
      "options": ["Very clear", "Mostly clear", "Somewhat clear", "Not clear", "Confusing"]
    },
    {
      "type": "rating",
      "label": "How would you rate your lender's communication?",
      "required": true,
      "order": 3,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "nps",
      "label": "How likely are you to recommend your lender?",
      "required": true,
      "order": 4,
      "options": null,
      "config": {
        "min": 0,
        "max": 10,
        "labels": {
          "min": "Not likely",
          "max": "Extremely likely"
        }
      }
    },
    {
      "type": "textarea",
      "label": "Any issues we should be aware of?",
      "required": false,
      "order": 5,
      "options": null,
      "config": {
        "rows": 4
      }
    }
  ]
}

