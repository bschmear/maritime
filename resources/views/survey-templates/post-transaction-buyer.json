{
  "id": "post-transaction-buyer",
  "name": "Post-Transaction Client Feedback (Buyer)",
"description": "Gather satisfaction data and agent performance insights after a purchase",
"public_description": "Please provide feedback regarding the home buying experience to assist in evaluating satisfaction and service quality",
  "type": "feedback",
  "icon": "fa-home",
  "category": "Post-Transaction",
  "questions": [
    {
      "type": "nps",
      "label": "How satisfied are you with your overall home buying experience?",
      "required": true,
      "order": 1,
      "options": null,
      "config": {
        "min": 0,
        "max": 10,
        "labels": {
          "min": "Not satisfied",
          "max": "Extremely satisfied"
        }
      }
    },
    {
      "type": "rating",
      "label": "How responsive was your agent?",
      "required": true,
      "order": 2,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "multiple_choice",
      "label": "Did you feel confident during the negotiation process?",
      "required": true,
      "order": 3,
      "options": ["Very confident", "Somewhat confident", "Neutral", "Not very confident", "Not confident at all"]
    },
    {
      "type": "textarea",
      "label": "What could have made your experience better?",
      "required": false,
      "order": 4,
      "options": null,
      "config": {
        "rows": 4
      }
    },
    {
      "type": "multiple_choice",
      "label": "Would you refer your agent to a friend or family member?",
      "required": true,
      "order": 5,
      "options": ["Yes, definitely", "Yes, probably", "Not sure", "Probably not", "Definitely not"]
    }
  ]
}

