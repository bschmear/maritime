{
  "id": "brokerage-experience",
  "name": "Brokerage Experience Survey",
  "description": "Gather broad satisfaction data across all clients or leads",
  "public_description": "Your opinion matters! Please take a moment to share your experience with our brokerage so we can continue improving the service we provide to all our clients",
  "type": "feedback",
  "icon": "fa-building",
  "category": "Internal",
  "questions": [
    {
      "type": "dropdown",
      "label": "How did you first hear about our brokerage?",
      "required": true,
      "order": 1,
      "options": ["Referral", "Online search", "Social media", "Advertisement", "Sign", "Event", "Other"]
    },
    {
      "type": "nps",
      "label": "How satisfied are you with your overall experience?",
      "required": true,
      "order": 2,
      "options": null,
      "config": {
        "min": 0,
        "max": 10,
        "labels": {
          "min": "Not satisfied",
          "max": "Extremely satisfied"
        }
      }
    },
    {
      "type": "rating",
      "label": "Did our team meet your expectations?",
      "required": true,
      "order": 3,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "multiple_choice",
      "label": "Would you use us again in the future?",
      "required": true,
      "order": 4,
      "options": ["Yes, definitely", "Yes, probably", "Not sure", "Probably not", "Definitely not"]
    },
    {
      "type": "textarea",
      "label": "What could we improve?",
      "required": false,
      "order": 5,
      "options": null,
      "config": {
        "rows": 4
      }
    }
  ]
}

