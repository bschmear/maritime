{
  "id": "lead-intake-seller",
  "name": "Lead Intake (Seller Lead Generator)",
"description": "Capture and qualify homeowners interested in selling",
"public_description": "Provide a few details about the property and selling plans to help determine next steps for potential listing opportunities",
  "type": "lead",
  "icon": "fa-home",
  "category": "Lead Generation",
  "questions": [
    {
      "type": "multiple_choice",
      "label": "Have you sold a property before?",
      "required": true,
      "order": 1,
      "options": ["Yes", "No"]
    },
    {
      "type": "dropdown",
      "label": "When are you planning to sell?",
      "required": true,
      "order": 2,
      "options": ["Within 1 month", "1-3 months", "3-6 months", "6-12 months", "Just exploring"]
    },
    {
      "type": "textarea",
      "label": "What's your estimated home value?",
      "required": false,
      "order": 3,
      "options": null,
      "config": {
        "placeholder": "e.g., $500,000"
      }
    },
    {
      "type": "multiple_choice",
      "label": "What's most important to you in an agent?",
      "required": true,
      "order": 4,
      "options": ["Speed of sale", "Highest price", "Communication", "Experience", "Marketing strategy"]
    },
    {
      "type": "multiple_choice",
      "label": "Would you like a free home valuation?",
      "required": true,
      "order": 5,
      "options": ["Yes", "No", "Maybe later"]
    }
  ]
}

