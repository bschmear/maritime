          { "question": 0, "equals": "Both buy and sell" }
        ]
      }
    },
    {
      "type": "dropdown",
      "label": "What's your target price range?",
      "required": false,
      "order": 5,
      "options": ["Under $200k", "$200k - $300k", "$300k - $400k", "$400k - $600k", "$600k - $800k", "$800k - $1M", "Over $1M"],
      "config": null,
      "conditional_logic": {
        "rules": [
          { "question": 0, "equals": "Buy a home" },
          { "question": 0, "equals": "Both buy and sell" }
        ]
      }
    },
    {
      "type": "multiple_choice",
      "label": "If selling, what type of property do you have?",
      "required": false,
