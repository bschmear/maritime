{
  "id": "lead-intake-new-agent",
  "name": "Lead Intake (Looking for a New Agent)",
  "description": "Qualify people who are looking for a new real estate agent to help with buying or selling",
  "public_description": "If you're exploring your options or looking for a new agent to work with, share a few quick details below so I can learn a bit about what you need.",
  "type": "lead",
  "icon": "fa-handshake",
  "category": "Lead Generation",
  "questions": [
    {
      "type": "multiple_choice",
      "label": "What are you looking to do?",
      "required": true,
      "order": 1,
      "options": ["Buy a home", "Sell a home", "Both buy and sell", "Just getting started / exploring"],
      "config": null,
      "conditional_logic": null
    },
    {
      "type": "multiple_choice",
      "label": "Are you currently working with another agent?",
      "required": true,
      "order": 2,
      "options": ["Yes, but considering a change", "No, I'm not working with anyone", "Just exploring for now"],
      "config": null,
      "conditional_logic": null
