    {
      "type": "textarea",
      "label": "What prompted you to look for a different agent?",
      "required": false,
      "order": 3,
      "options": null,
      "config": {
        "placeholder": "Example: Poor communication, lack of market knowledge, availability issues, etc.",
        "rows": 3
      },
      "conditional_logic": {
        "rules": [
          { "question": 1, "equals": "Yes, but considering a change" }
        ]
      }
    },
    {
