      "conditional_logic": {
        "rules": [
          { "question": 0, "equals": "Sell a home" },
          { "question": 0, "equals": "Both buy and sell" }
        ]
      }
    },
    {
      "type": "dropdown",
      "label": "When would you like to sell?",
      "required": false,
      "order": 7,
      "options": ["Within 1 month", "1-3 months", "3-6 months", "6-12 months", "Just exploring / planning ahead"],
      "config": null,
      "conditional_logic": {
        "rules": [
          { "question": 0, "equals": "Sell a home" },
          { "question": 0, "equals": "Both buy and sell" }
