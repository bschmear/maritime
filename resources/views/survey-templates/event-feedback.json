{
  "id": "event-feedback",
  "name": "Event Feedback (Client Appreciation / Seminar / Webinar)",
"description": "Improve future events",
"public_description": "Please provide feedback regarding the event to assist in evaluating satisfaction and informing improvements for future events",
  "type": "feedback",
  "icon": "fa-calendar-check",
  "category": "Events",
  "questions": [
    {
      "type": "dropdown",
      "label": "How did you hear about this event?",
      "required": true,
      "order": 1,
      "options": ["Email invitation", "Social media", "Website", "Friend/Colleague", "Agent", "Other"]
    },
    {
      "type": "textarea",
      "label": "What did you enjoy most?",
      "required": false,
      "order": 2,
      "options": null,
      "config": {
        "rows": 4
      }
    },
    {
      "type": "rating",
      "label": "Was the information valuable or relevant?",
      "required": true,
      "order": 3,
      "options": null,
      "config": {
        "max": 5,
        "icon": "star"
      }
    },
    {
      "type": "multiple_choice",
      "label": "Would you attend again?",
      "required": true,
      "order": 4,
      "options": ["Yes, definitely", "Yes, probably", "Not sure", "Probably not", "Definitely not"]
    },
    {
      "type": "textarea",
      "label": "Suggestions for future events?",
      "required": false,
      "order": 5,
      "options": null,
      "config": {
        "rows": 4
      }
    }
  ]
}

