{
  "fields": {
    "name": {
      "label": "Name",
      "type": "text",
      "required": true
    },
    "slug": {
      "label": "Slug",
      "type": "text",
      "required": false,
      "description": "Leave blank to generate from name when creating."
    },
    "category_id": {
      "label": "Category",
      "type": "record",
      "typeDomain": "AssetOptionCategory",
      "create": true
    },
    "input_type": {
      "label": "Input type",
      "type": "select",
      "required": true,
      "enum": "App\\Enums\\AssetOption\\AssetOptionInputType"
    },
    "is_required": {
      "label": "Required",
      "type": "boolean"
    },
    "allow_multiple": {
      "label": "Allow multiple values",
      "type": "boolean"
    },
    "min_select": {
      "label": "Minimum selections",
      "type": "number",
      "default": 0
    },
    "max_select": {
      "label": "Maximum selections",
      "type": "number",
      "default": 1
    },
    "active": {
      "label": "Active",
      "type": "boolean",
      "default": true
    },
    "is_global": {
      "label": "Global option",
      "type": "boolean",
      "default": false,
      "description": "Available on any line via Add Global Option; no catalog assignment needed."
    },
    "created_at": {
      "label": "Created",
      "type": "datetime",
      "readOnly": true
    },
    "updated_at": {
      "label": "Updated",
      "type": "datetime",
      "readOnly": true
    }
  }
}
