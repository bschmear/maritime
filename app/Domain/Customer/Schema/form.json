{
  "settings": {
    "max_width": "4xl"
  },
  "form": {
    "contact": {
      "label": "Contact",
      "fields": [
        { "key": "first_name", "required": true },
        { "key": "last_name", "required": true },
        { "key": "email", "required": false },
        { "key": "secondary_email", "required": false },
        { "key": "phone", "required": false },
        { "key": "mobile", "required": false },
        { "key": "inactive", "required": false },
        { "key": "preferred_contact_method", "required": false },
        { "key": "preferred_contact_time", "required": false },
        { "key": "notes", "required": false }
      ]
    },
    "company_info": {
      "label": "Company",
      "fields": [
        { "key": "company", "required": false },
        { "key": "position", "required": false },
        { "key": "title", "required": false }
      ]
    },
    "customer_profile": {
      "label": "Customer profile",
      "fields": [
