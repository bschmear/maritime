        { "key": "currency", "required": false }
      ]
    },
    "billing_tax": {
      "label": "Billing & Tax",
      "fields": [
        { "key": "credit_limit", "required": false },
        { "key": "tax_id", "required": false },
        { "key": "tax_exempt", "required": false },
        { "key": "tax_exempt_reason", "required": false },
        { "key": "purchase_order_required", "required": false }
      ]
    }
  },
  "sublists": [

  ]
