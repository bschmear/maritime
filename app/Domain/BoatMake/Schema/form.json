{
  "settings": {
    "max_width": "2xl"
  },
  "form": {
    "primary": {
      "label": "Primary Information",
      "fields": [
        {
          "key": "display_name",
          "required": true
        },
        {
          "key": "asset_types",
          "required": true
        },
        {
          "key": "vendor_id"
        },
        {
          "key": "website_url"
        },
        {
          "key": "description"
        }
      ]
    },
    "branding": {
      "label": "Brand logo",
      "fields": [
        {
          "key": "default_brand_image"
        },
        {
          "key": "use_default_logo",
          "conditional": {
            "key": "default_brand_image",
            "operator": "is_not_empty"
          }
        },
        {
          "key": "custom_logo_id",
          "conditional": {
            "key": "use_default_logo",
            "value": false,
            "operator": "equals"
          }
        }
      ]
    }
  },
  "sublists": [
    {
      "label": "Models",
      "domain": "Asset",
      "per_page": 25
    }
  ]
}
