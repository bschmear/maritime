{
  "settings": {
    "max_width": "4xl"
  },
  "form": {
    "primary": {
      "label": "Delivery Details",
      "fields": [
        {
          "key": "customer_id",
          "required": true,
          "addNew": true
        },
        {
          "key": "asset_unit_id",
          "required": true
        },
        {
          "key": "work_order_id",
          "required": false
        },
        {
          "key": "technician_id",
          "required": false
        },
        {
          "key": "scheduled_at",
          "required": true
        },
        {
          "key": "estimated_arrival_at",
          "required": false
        },
        {
          "key": "status",
          "required": true
        },
        {
          "key": "internal_notes",
          "required": false
        },
        {
          "key": "customer_notes",
          "required": false
        }
      ]
    },
    "address": {
      "label": "Address",
      "is_address": true,
      "fields": [
        {
          "key": "address_line_1",
          "required": false,
          "tag": "street"
        },
        {
          "key": "address_line_2",
          "required": false,
          "tag": "unit"
        },
        {
          "key": "city",
          "required": false,
          "tag": "city"
        },
        {
          "key": "state",
          "required": false,
          "tag": "state"
        },
        {
          "key": "postal_code",
          "required": false,
          "tag": "postal_code"
        },
        {
          "key": "country",
          "required": false,
          "tag": "country"
        },
        {
          "key": "latitude",
          "hidden": true,
          "tag": "latitude"
        },
        {
          "key": "longitude",
          "hidden": true,
          "tag": "longitude"
        }
      ]
    }
  },

  "sublists": [
    {
      "label": "Checklist",
      "domain": "DeliveryChecklistItem"
    }
  ]
}
