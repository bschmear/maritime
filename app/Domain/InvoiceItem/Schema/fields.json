{
    "invoice_id": {
      "label": "Invoice",
      "type": "record",
      "typeDomain": "Invoice",
      "required": true,
      "hidden": true
    },
  
    "transaction_item_id": {
      "label": "Source Transaction Item",
      "type": "record",
      "typeDomain": "TransactionItem",
      "nullable": true,
      "hidden": true
    },
  
    "type": {
      "label": "Type",
      "type": "select",
      "options": [
        { "id": "asset", "name": "Asset" },
        { "id": "inventory", "name": "Inventory" },
        { "id": "service", "name": "Service" },
        { "id": "fee", "name": "Fee" }
      ],
      "nullable": true,
      "help": "Type of line item"
    },
  
    "itemable_type": {
      "label": "Item Type",
      "type": "text",
      "hidden": true
    },
  
    "itemable_id": {
      "label": "Item Reference",
      "type": "number",
      "hidden": true
    },
  
    "name": {
      "label": "Item Name",
      "type": "text",
      "required": true
    },
  
    "description": {
      "label": "Description",
      "type": "textarea",
      "nullable": true
    },
  
    "quantity": {
      "label": "Quantity",
      "type": "number",
      "step": 0.01,
      "default": 1,
      "required": true
    },
  
    "unit_price": {
      "label": "Unit Price",
      "type": "currency",
      "default": 0,
      "required": true
    },
  
    "discount": {
      "label": "Discount",
      "type": "currency",
      "default": 0,
      "help": "Flat discount applied to this line"
    },
  
    "subtotal": {
      "label": "Subtotal",
      "type": "currency",
      "readOnly": true,
      "help": "Auto-calculated (qty × price - discount)"
    },
  
    "taxable": {
      "label": "Taxable",
      "type": "boolean",
      "default": true
    },
  
    "tax_rate": {
      "label": "Tax Rate (%)",
      "type": "number",
      "step": 0.01,
      "nullable": true,
      "help": "Tax rate as percentage"
    },
  
    "tax_amount": {
      "label": "Tax Amount",
      "type": "currency",
      "readOnly": true,
      "help": "Auto-calculated from subtotal × tax rate"
    },
  
    "total": {
      "label": "Line Total",
      "type": "currency",
      "readOnly": true,
      "help": "Subtotal + Tax"
    },
  
    "position": {
      "label": "Position",
      "type": "number",
      "default": 0,
      "hidden": true
    },
  
    "created_at": {
      "label": "Created At",
      "type": "datetime",
      "readOnly": true
    },
  
    "updated_at": {
      "label": "Updated At",
      "type": "datetime",
      "readOnly": true
    }
  }