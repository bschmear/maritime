{
  "settings": {
    "max_width": "4xl"
  },
  "form": {
    "general": {
      "label": "General Information",
      "fields": [
        { "key": "display_name", "required": true },
        { "key": "company_name", "required": false },
        { "key": "vendor_type", "required": false },
        { "key": "industry", "required": false },
        { "key": "vendor_code", "required": false },
        { "key": "status_id", "required": true },
        { "key": "status_reason", "required": false },
        { "key": "rating", "required": false },
        { "key": "payment_terms", "required": false },
        { "key": "credit_limit", "required": false },
        { "key": "website", "required": false },
        { "key": "linkedin", "required": false },
        { "key": "facebook", "required": false },
        { "key": "is_verified", "required": false }
      ]
    },
    "address": {
      "label": "Location",
      "is_address": true,
      "fields": [
        { "key": "address_line_1", "required": false, "tag": "street" },
        { "key": "address_line_2", "required": false, "tag": "unit" },
        { "key": "city", "required": false, "tag": "city" },
        { "key": "state", "required": false, "tag": "state" },
        { "key": "postal_code", "required": false, "tag": "postal_code" },
        { "key": "country", "required": false, "tag": "country" },
        { "key": "latitude", "hidden": true, "tag": "latitude" },
        { "key": "longitude", "hidden": true, "tag": "longitude" }
      ]
    },
    "contracts": {
      "label": "Contract Details",
      "fields": [
        { "key": "contract_start", "required": false },
        { "key": "contract_end", "required": false },
        { "key": "contract_status", "required": false }
      ]
    },
    "quickbooks": {
      "label": "QuickBooks & Payments",
      "fields": [
        { "key": "quickbooks_id", "required": false },
        { "key": "qbo_acct_num", "required": false },
        { "key": "print_on_check_name", "required": false },
        { "key": "term_ref_name", "required": false },
        { "key": "open_balance", "required": false },
        { "key": "overdue_balance", "required": false },
        { "key": "vendor_1099", "required": false },
        { "key": "ach_bank_name", "required": false },
        { "key": "ach_account_number", "required": false },
        { "key": "ach_routing_number", "required": false },
        { "key": "tax_identifier", "required": false }
      ]
    }
  },
  "sublists": [
    {
      "label": "Contacts",
      "domain": "Contact",
      "modelRelationship": "linkedContacts",
      "relationshipType": "ManyToMany",
      "pivotColumns": [
        {
          "key": "portal_access",
          "label": "Manufacturer portal",
          "type": "boolean",
          "toggleRoute": "vendors.contacts.portal-access",
          "toggleRequestKey": "portal_access"
        }
      ],
      "rowActions": [
        {
          "route": "vendors.contacts.send-vendor-portal-link",
          "title": "Email manufacturer portal link",
          "icon": "outgoing_mail",
          "requiresEmail": true
        }
      ]
    },
    {
      "label": "Bills",
      "domain": "Bill",
      "modelRelationship": "bills"
    },
    {
      "label": "Bill payments",
      "domain": "BillPayment",
      "modelRelationship": "billPayments"
    },
    {
      "label": "Warranty claims",
      "domain": "WarrantyClaim",
      "modelRelationship": "warrantyClaims"
    },
    {
      "label": "Communications",
      "domain": "Communication",
      "modelRelationship": "communications",
      "sublistKind": "morphCommunication"
    }
  ]
}
