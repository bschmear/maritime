{
    "boat_show_id": {
        "label": "Boat Show",
        "type": "record",
        "typeDomain": "BoatShow",
        "relationship": "show",
        "validation": "required|exists:boat_shows,id",
        "help": "Parent boat show"
    },
    "display_name": {
        "label": "Display Name",
        "type": "text",
        "validation": "required|string|max:255",
        "help": "Label for this event (e.g. Miami 2026)"
    },
    "year": {
        "label": "Year",
        "type": "number",
        "validation": "required|integer|min:2000|max:2100",
        "help": "Event year"
    },
    "starts_at": {
        "label": "Starts",
        "type": "date",
        "validation": "nullable|date",
        "help": "Start date"
    },
    "ends_at": {
        "label": "Ends",
        "type": "date",
        "validation": "nullable|date|after_or_equal:starts_at",
        "help": "End date"
    },
    "venue": {
        "label": "Venue",
        "type": "text",
        "validation": "nullable|string|max:255",
        "help": "Venue or marina name"
    },
    "city": {
        "label": "City",
        "type": "text",
        "validation": "nullable|string|max:255"
    },
    "state": {
        "label": "State / Region",
        "type": "text",
        "validation": "nullable|string|max:255"
    },
    "country": {
        "label": "Country",
        "type": "text",
        "validation": "nullable|string|max:255"
    },
    "latitude": {
        "label": "Latitude",
        "type": "number",
        "validation": "nullable|numeric"
    },
    "longitude": {
        "label": "Longitude",
        "type": "number",
        "validation": "nullable|numeric"
    },
    "booth": {
        "label": "Booth",
        "type": "text",
        "validation": "nullable|string|max:255",
        "help": "Booth or space identifier"
    },
    "active": {
        "label": "Active",
        "type": "boolean",
        "validation": "boolean",
        "default": true
    },
    "meta": {
        "label": "Additional Data",
        "type": "json",
        "validation": "nullable|array",
        "hidden": true
    },
    "created_at": {
        "label": "Created At",
        "type": "datetime",
        "readOnly": true
    },
    "updated_at": {
        "label": "Updated At",
        "type": "datetime",
        "readOnly": true
    }
}
