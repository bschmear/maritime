{
  "settings": {
    "max_width": "4xl"
  },
  "form": {
    "primary": {
      "label": "Claim",
      "fields": [
        { "key": "vendor_id", "required": true },
        { "key": "work_order_id", "required": false },
        { "key": "subsidiary_id", "required": false },
        { "key": "location_id", "required": false },
        { "key": "status", "required": true },
        { "key": "notes", "required": false },
        { "key": "rejection_reason", "required": false }
      ]
    },
    "secondary": {
      "label": "Timeline",
      "fields": [
        { "key": "total_amount", "required": false },
        { "key": "submitted_at", "required": false },
        { "key": "approved_at", "required": false },
        { "key": "paid_at", "required": false },
        { "key": "voided_at", "required": false }
      ]
    }
  },
  "sublists": [
    {
      "label": "Images",
      "domain": "InventoryImage",
      "modelRelationship": "images"
    }
  ]
}
