{
  "settings": {
    "max_width": "5xl"
  },
  "form": {
    "general": {
      "label": "General",
      "fields": [
        {
          "key": "type",
          "required": true
        },
        {
          "key": "display_name",
          "required": true
        },
        {
          "key": "has_variants"
        },
        {
          "key": "make_id"
        },
        {
          "key": "model"
        },
        {
          "key": "year"
        },
        {
          "key": "default_cost"
        },
        {
          "key": "default_price"
        }
      ]
    },

    "specs": {
      "label": "Specifications",
      "type": "specs",
      "conditional": {
        "key": "has_variants",
        "value": false,
        "operator": "equals"
      }
    },

    "details": {
      "label": "Details",
      "fields": [
        {
          "key": "inactive"
        }
      ]
    },

    "lifecycle": {
      "label": "Lifecycle & Notes",
      "fields": [
        {
          "key": "attributes"
        },
        {
          "key": "description"
        }
      ]
    }
  },
  "sublists": [
    {
      "label": "Variants",
      "domain": "AssetVariant",
      "modelRelationship": "variants",
      "conditional": {
        "key": "has_variants",
        "value": true,
        "operator": "equals"
      },
      "routes": {
        "selectForm": "assets.variants.select-form",
        "index": "assets.variants.index",
        "show": "assets.variants.show"
      }
    },
    {
      "label": "Asset Units",
      "domain": "AssetUnit",
      "modelRelationship": "units"
    },
    {
      "label": "Transactions",
      "domain": "Transaction"
    },
    {
      "label": "Images",
      "domain": "InventoryImage",
      "modelRelationship": "images"
    },
    {
      "label": "Documents",
      "domain": "Document"
    }
  ]
}