{
  "type": {
    "label": "Asset Category",
    "type": "select",
    "enum": "App\\Enums\\Inventory\\AssetType",
    "required": true,
    "default": 1
  },
  "display_name": {
    "label": "Asset Name",
    "type": "text",
    "required": true,
    "placeholder": "Enter asset name"
  },
  "slug": {
    "label": "Slug",
    "type": "text",
    "disabled": true,
    "help": "Auto-generated from name"
  },
  "inactive": {
    "label": "Inactive",
    "type": "boolean",
    "default": false
  },
  "has_variants": {
    "label": "This asset has variants",
    "type": "boolean",
    "default": false,
    "help": "When enabled, specifications are stored per variant instead of on this asset. Units must pick a variant."
  },
  "make_id": {
    "label": "Brand",
    "type": "record",
    "typeDomain": "BoatMake",
    "addNew": true,
    "filterby": "type",
    "record_filter_field": "asset_types"
  },
  "model": {
    "label": "Model",
    "type": "text",
    "placeholder": "Model name"
  },
  "year": {
    "label": "Year",
    "type": "text",
    "placeholder": "Year"
  },
  "length": {
    "label": "Length",
    "type": "measurement",
    "help": "Stored in millimetres. Shown in feet and inches for now; account display units will be configurable later.",
    "spec": true
  },
  "width": {
    "label": "Width",
    "type": "measurement",
    "help": "Stored in millimetres. Shown in feet and inches for now; account display units will be configurable later.",
    "spec": true
  },
  "hull_type": {
    "label": "Hull type",
    "type": "select",
    "enum": "App\\Enums\\Inventory\\HullType",
    "spec": true,
    "conditional": {
      "key": "type",
      "value": 1,
      "operator": "equals"
    }
  },
  "hull_material": {
    "label": "Hull material",
    "type": "select",
    "enum": "App\\Enums\\Inventory\\HullMaterial",
    "spec": true,
    "conditional": {
      "key": "type",
      "value": 1,
      "operator": "equals"
    }
  },
  "boat_type": {
    "label": "Boat type",
    "type": "select",
    "enum": "App\\Enums\\Inventory\\BoatType",
    "spec": true,
    "conditional": {
      "key": "type",
      "value": 1,
      "operator": "equals"
    }
  },
  "default_cost": {
    "label": "Default Cost",
    "type": "currency",
    "placeholder": "0.00"
  },
  "default_price": {
    "label": "Default Price",
    "type": "currency",
    "placeholder": "0.00"
  },
  "description": {
    "label": "Description",
    "type": "textarea",
    "placeholder": "Asset description"
  },
  "created_at": {
    "label": "Created",
    "type": "datetime",
    "disabled": true
  },
  "updated_at": {
    "label": "Updated",
    "type": "datetime",
    "disabled": true
  }
}
