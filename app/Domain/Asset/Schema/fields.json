{
  "type": {
    "label": "Asset Type",
    "type": "select",
    "enum": "App\\Enums\\Inventory\\AssetType",
    "required": true,
    "default": 1
  },
  "display_name": {
    "label": "Asset Name",
    "type": "text",
    "required": true,
    "placeholder": "Enter asset name"
  },
  "slug": {
    "label": "Slug",
    "type": "text",
    "disabled": true,
    "help": "Auto-generated from name"
  },
  "inactive": {
    "label": "Inactive",
    "type": "boolean",
    "default": false
  },
  "has_variants": {
    "label": "This asset has variants",
    "type": "boolean",
    "default": false,
    "help": "When enabled, specifications are stored per variant instead of on this asset. Units must pick a variant."
  },
  "make_id": {
    "label": "Brand",
    "type": "record",
    "typeDomain": "BoatMake",
    "addNew": true,
    "filterby": "type",
    "record_filter_field": "asset_types"
  },
  "model": {
    "label": "Model",
    "type": "text",
    "placeholder": "Model name"
  },
  "year": {
    "label": "Year",
    "type": "text",
    "placeholder": "Year"
  },
  "default_cost": {
    "label": "Default Cost",
    "type": "currency",
    "placeholder": "0.00"
  },
  "default_price": {
    "label": "Default Price",
    "type": "currency",
    "placeholder": "0.00"
  },
  "description": {
    "label": "Description",
    "type": "textarea",
    "placeholder": "Asset description"
  },
  "attributes": {
    "label": "Additional Attributes",
    "type": "json",
    "help": "Custom attributes as JSON"
  },
  "created_at": {
    "label": "Created",
    "type": "datetime",
    "disabled": true
  },
  "updated_at": {
    "label": "Updated",
    "type": "datetime",
    "disabled": true
  }
}